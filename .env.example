# ─── Web server ────────────────────────────────────────────────────────────────
# Bind IP address for the HTTP server. Use 0.0.0.0 to listen on all interfaces
# (required when running inside Docker). Defaults to 127.0.0.1 (loopback only).
ROUNDCHAT_HOST=127.0.0.1
# TCP port the HTTP server listens on. Defaults to 7979.
ROUNDCHAT_PORT=7979

# ─── Incoming mail ─────────────────────────────────────────────────────────────
# Set IMAP_HOST to enable IMAP (preferred). Leave blank to fall back to POP3.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_TLS=true
# Set to true to skip TLS certificate verification (e.g. for self-signed certs).
IMAP_TLS_INSECURE=false

# Used only when IMAP_HOST is empty.
POP3_HOST=pop3.example.com
POP3_PORT=995
POP3_TLS=true
# Set to true to skip TLS certificate verification (e.g. for self-signed certs).
POP3_TLS_INSECURE=false
# Interval in seconds between POP3 polls.
POP3_POLL_INTERVAL=30

# ─── Outgoing mail ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_TLS=true

# ─── Contacts (CardDAV) ────────────────────────────────────────────────────────
CARDDAV_URL=https://carddav.example.com/users/{email}/addressbook/

# ─── File sharing (WebDAV) ─────────────────────────────────────────────────────
WEBDAV_URL=https://webdav.example.com/files/{email}/
