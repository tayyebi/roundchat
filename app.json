{
  "expo": {
    "name": "RoundChat",
    "slug": "roundchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.roundchat.app"
    },
    "android": {
      "package": "com.roundchat.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "IMAP_HOST": "$IMAP_HOST",
      "IMAP_PORT": "$IMAP_PORT",
      "IMAP_TLS": "$IMAP_TLS",
      "POP3_HOST": "$POP3_HOST",
      "POP3_PORT": "$POP3_PORT",
      "POP3_TLS": "$POP3_TLS",
      "POP3_POLL_INTERVAL": "$POP3_POLL_INTERVAL",
      "SMTP_HOST": "$SMTP_HOST",
      "SMTP_PORT": "$SMTP_PORT",
      "SMTP_TLS": "$SMTP_TLS",
      "CARDDAV_URL": "$CARDDAV_URL",
      "WEBDAV_URL": "$WEBDAV_URL"
    }
  }
}
